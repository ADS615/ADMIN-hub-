    -- Touch joystick logic
    local joyRadius = 55 -- pixels from center
    local joyCenter = Vector2.new(0, 0)
    local joyDelta = Vector2.new(0, 0)
    local joyTouchId = nil

    JoyBase.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch and not joyTouchId then
            joyTouchId = inp
            joyCenter = JoyBase.AbsolutePosition + JoyBase.AbsoluteSize / 2
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if inp == joyTouchId then
            local delta = Vector2.new(inp.Position.X - joyCenter.X, inp.Position.Y - joyCenter.Y)
            local len = delta.Magnitude
            if len > joyRadius then
                delta = delta / len * joyRadius
            end
            joyDelta = delta / joyRadius
            JoyKnob.Position = UDim2.new(0.5, delta.X - 22, 0.5, delta.Y - 22)
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp == joyTouchId then
            joyTouchId = nil
            joyDelta = Vector2.new(0, 0)
            TweenService:Create(JoyKnob, TweenInfo.new(0.1), {
                Position = UDim2.new(0.5, -22, 0.5, -22)
            }):Play()
        end
    end)

    -- Return delta accessors
    return function()
        return joyDelta, GoUp, GoDown
    end
end

local GetMobileInput = nil

local function EnableFly()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    hum.PlatformStand = true

    local BV = Instance.new("BodyVelocity")
    BV.Velocity = Vector3.zero
    BV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    BV.Parent = root
    State.BodyVelocity = BV

    local BG = Instance.new("BodyGyro")
    BG.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    BG.P = 1e4
    BG.CFrame = root.CFrame
    BG.Parent = root
    State.BodyGyro = BG

    if IsMobile then
        GetMobileInput = CreateMobileFlyControls()
    end

    FlyConn = RunService.RenderStepped:Connect(function()
        local cf = Camera.CFrame
        local vel = Vector3.zero
        local spd = State.FlySpeed

        if IsMobile and GetMobileInput then
            local delta, goUp, goDown = GetMobileInput()
            -- Forward/back from joystick Y, strafe from joystick X
            vel = vel + cf.LookVector * (-delta.Y * spd)
            vel = vel + cf.RightVector * (delta.X * spd)
            if goUp   then vel = vel + Vector3.new(0, spd, 0) end
            if goDown then vel = vel - Vector3.new(0, spd, 0) end
        else
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cf.LookVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cf.LookVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cf.RightVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cf.RightVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then vel = vel + Vector3.new(0, spd, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then vel = vel - Vector3.new(0, spd, 0) end
        end

        BV.Velocity = vel
        BG.CFrame = cf
    end)
end

local function DisableFly()
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
    end
    if State.BodyVelocity then State.BodyVelocity:Destroy() State.BodyVelocity = nil end
    if State.BodyGyro then State.BodyGyro:Destroy() State.BodyGyro = nil end
    if FlyConn then FlyConn:Disconnect() FlyConn = nil end
    if FlyControlsFrame then FlyControlsFrame:Destroy() FlyControlsFrame = nil end
    GetMobileInput = nil
end

