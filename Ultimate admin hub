-- LOGIC LOOPS
local function getTarget()
    local closest, dist = nil, HUB_SETTINGS.FOV
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos, vis = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if mag < dist then dist = mag closest = p.Character.HumanoidRootPart end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    pcall(function()
        local char = LocalPlayer.Character
        if char and char:FindFirstChildOfClass("Humanoid") then
            char:FindFirstChildOfClass("Humanoid").WalkSpeed = HUB_SETTINGS.WALKSPEED
            char:FindFirstChildOfClass("Humanoid").JumpPower = HUB_SETTINGS.JUMPPOWER
            
            if HUB_SETTINGS.NOCLIP then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end

        local target = getTarget()
        if target and HUB_SETTINGS.AIMLOCK then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), HUB_SETTINGS.SMOOTHNESS)
        end
        
        -- ESP Logic
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local high = p.Character:FindFirstChild("DeltaHighlight") or Instance.new("Highlight", p.Character)
                high.Name = "DeltaHighlight"
                high.Enabled = HUB_SETTINGS.TRACERS
                high.FillColor = (target and target.Parent == p.Character) and Color3.new(1,0,0) or Color3.new(0,1,1)
            end
        end
    end)
end)

