-- ============================================================
-- INPUT HANDLING (PC)
-- ============================================================
if not isMobile then
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Settings.AimKey then
            aiming = true
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Settings.AimKey then
            aiming = false
        end
    end)
end

-- ============================================================
-- MAIN LOOP
-- ============================================================
local lastMobileAim = 0

RunService.RenderStepped:Connect(function()
    -- Update FOV circle position (PC only)
    if not isMobile and Settings.FOVEnabled then
        local mousePos = UserInputService:GetMouseLocation()
        FOVCircle.Position = mousePos
        FOVCircle.Visible = true
    end

    -- Refresh highlights
    RefreshHighlights()

    -- PC Aimbot
    if not isMobile then
        if Settings.AimbotEnabled and aiming then
            local target = GetClosestTarget()
            if target then
                AimAt(target)
            end
        end
    else
        -- Mobile auto aim
        if Settings.AimbotEnabled and Settings.MobileAutoAim then
            local now = tick()
            if now - lastMobileAim >= Settings.MobileAimInterval then
                lastMobileAim = now
                local target = GetClosestTarget()
                if target then
                    AimAt(target)
                end
            end
        end
    end
end)

-- ============================================================
-- CLEANUP
-- ============================================================
LocalPlayer.CharacterRemoving:Connect(function()
    for _, player in ipairs(Players:GetPlayers()) do
        RemoveHighlight(player)
    end
end)

print("[Rivals Aimbot] Loaded | Mobile: " .. tostring(isMobile) .. " | Silent Aim: " .. tostring(Settings.SilentAim))
