	fovCircle.Position = UDim2.new(0, center.X - CONFIG.FOV_RADIUS, 0, center.Y - CONFIG.FOV_RADIUS)
	fovCircle.Visible = CONFIG.FOV_RADIUS > 0 and aimbotEnabled
end

