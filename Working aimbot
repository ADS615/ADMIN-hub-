-- ============================================================
--  CONFIG
-- ============================================================
local CONFIG = {
	ATTACK_RANGE   = 150,
	FIRE_RATE      = 0.35,
	BULLET_SPEED   = 250,
	BULLET_DAMAGE  = 25,
	LEAD_SHOT      = true,
	AIM_SMOOTHNESS = 0.18,   -- 0 = instant snap, 1 = very slow
	WALL_CHECK     = true,   -- skip targets behind walls
	TOGGLE_KEY     = Enum.KeyCode.F,
	STICKY_AIM     = true,   -- stay on same target until dead/out of range
	FOV_RADIUS     = 300,    -- screen-space FOV circle radius (px); 0 = disabled
}

