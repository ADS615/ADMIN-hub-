local pages = {}
local function makePage(name)
    local p = Instance.new("ScrollingFrame", container)
    p.Size = UDim2.new(1, 0, 1, 0)
    p.BackgroundTransparency = 1
    p.Visible = false
    p.CanvasSize = UDim2.new(0, 0, 0, 800)
    p.ScrollBarThickness = 0
    Instance.new("UIListLayout", p).Padding = UDim.new(0, 6)
    
    local b = Instance.new("TextButton", sidebar)
    b.Size = UDim2.new(0.9, 0, 0, 40)
    b.Text = name:upper()
    b.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    b.TextColor3 = Color3.new(0.7, 0.7, 0.7)
    b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b)
    Instance.new("UIListLayout", sidebar).Padding = UDim.new(0, 5)
    
    b.MouseButton1Click:Connect(function()
        for _, pg in pairs(pages) do pg.Visible = false end
        p.Visible = true
    end)
    pages[name] = p
    return p
end

local function addToggle(pg, txt, cb)
    local active = false
    local t = Instance.new("TextButton", pg)
    t.Size = UDim2.new(0.98, 0, 0, 35)
    t.BackgroundColor3 = Color3.fromRGB(28, 28, 32)
    t.Text = txt .. ": OFF"
    t.TextColor3 = Color3.new(1,1,1)
    t.Font = Enum.Font.Gotham
    Instance.new("UICorner", t)
    t.MouseButton1Click:Connect(function()
        active = not active
        t.Text = txt .. (active and ": ON" or ": OFF")
        t.BackgroundColor3 = active and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(28, 28, 32)
        cb(active)
    end)
end

