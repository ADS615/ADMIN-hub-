-- // MAIN LOOPS // --
RunService.RenderStepped:Connect(function()
    fovCircle.Visible = S.Combat.Aimbot and S.Combat.ShowFOV
    fovCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    fovCircle.Radius = S.Combat.FOV
    
    if S.Combat.Lock and S.Combat.Aimbot then
        local target, maxD = nil, S.Combat.FOV
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(S.Combat.Part) then
                local sp, on = Camera:WorldToViewportPoint(p.Character[S.Combat.Part].Position)
                if on then
                    local d = (Vector2.new(sp.X, sp.Y) - fovCircle.Position).Magnitude
                    if d < maxD then maxD = d target = p.Character[S.Combat.Part] end
                end
            end
        end
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), S.Combat.Smooth)
        end
    end
end)

UserInputService.JumpRequest:Connect(function()
    if S.Movement.InfJump and LocalPlayer.Character then
        LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

RunService.Stepped:Connect(function()
    if S.Movement.NoClip and LocalPlayer.Character then
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

