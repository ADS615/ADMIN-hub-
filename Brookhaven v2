local dragging, dragStart, startPos
TitleBar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = i.Position
        startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local delta = i.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

local function MakeSection(title)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 22)
    lbl.BackgroundTransparency = 1
    lbl.Text = "  " .. title
    lbl.TextColor3 = Color3.fromRGB(130, 130, 255)
    lbl.TextSize = 12
    lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = Scroll
end

local function MakeButton(label, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 38)
    btn.BackgroundColor3 = color or Color3.fromRGB(30, 30, 55)
    btn.Text = label
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 13
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.Parent = Scroll
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

local function MakeToggle(label, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 38)
    frame.BackgroundColor3 = Color3.fromRGB(22, 22, 38)
    frame.BorderSizePixel = 0
    frame.Parent = Scroll
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.7, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(220, 220, 220)
    lbl.TextSize = 13
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = frame

    local state = default or false

    local pill = Instance.new("TextButton")
    pill.Size = UDim2.new(0, 44, 0, 22)
    pill.Position = UDim2.new(1, -54, 0.5, -11)
    pill.BackgroundColor3 = state and Color3.fromRGB(80, 80, 200) or Color3.fromRGB(60, 60, 60)
    pill.Text = ""
    pill.BorderSizePixel = 0
    pill.Parent = frame
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Parent = pill
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    pill.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(pill, TweenInfo.new(0.15), {
            BackgroundColor3 = state and Color3.fromRGB(80, 80, 200) or Color3.fromRGB(60, 60, 60)
        }):Play()
        TweenService:Create(knob, TweenInfo.new(0.15), {
            Position = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
        }):Play()
        callback(state)
    end)
end

local function Notify(msg, color)
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 240, 0, 36)
    notif.Position = UDim2.new(0.5, -120, 0, -40)
    notif.BackgroundColor3 = color or Color3.fromRGB(30, 30, 60)
    notif.TextColor3 = Color3.fromRGB(255, 255, 255)
    notif.Text = msg
    notif.TextSize = 13
    notif.Font = Enum.Font.GothamBold
    notif.BorderSizePixel = 0
    notif.ZIndex = 10
    notif.Parent = ScreenGui
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 8)
    TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -120, 0, 14)}):Play()
    task.delay(2.5, function()
        TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -120, 0, -40)}):Play()
        task.delay(0.3, function() notif:Destroy() end)
    end)
end

local function GetChar() return LocalPlayer.Character end
local function GetHRP()
    local c = GetChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function GetHum()
    local c = GetChar()
    return c and c:FindFirstChildOfClass("Humanoid")
end

MakeSection("-- Ban Bypass --")

MakeButton("Auto Unban - Remove Barriers", Color3.fromRGB(180, 40, 40), function()
    local removed = 0
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        if obj:IsA("BasePart") or obj:IsA("UnionOperation") then
            if name:find("ban") or name:find("barrier") or name:find("block") or
               name:find("wall") or name:find("invisible") or name:find("forcefield") then
                if obj.CanCollide and obj.Transparency >= 0.8 then
                    obj.CanCollide = false
                    obj.Transparency = 1
                    removed = removed + 1
                end
            end
            if obj.Transparency == 1 and obj.CanCollide then
                obj.CanCollide = false
                removed = removed + 1
            end
        end
        if obj:IsA("ForceField") then
            obj:Destroy()
            removed = removed + 1
        end
    end
    Notify("Removed " .. removed .. " barriers!", Color3.fromRGB(40, 150, 40))
end)

MakeButton("Bypass House Door", Color3.fromRGB(150, 60, 20), function()
    local count = 0
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        if obj:IsA("BasePart") and (name:find("door") or name:find("gate") or name:find("entry")) then
            obj.CanCollide = false
            count = count + 1
        end
    end
    Notify("Bypassed " .. count .. " doors!", Color3.fromRGB(200, 120, 30))
end)

MakeSection("-- Teleport --")

MakeButton("Teleport to Player", Color3.fromRGB(30, 80, 160), function()
    local existing = ScreenGui:FindFirstChild("PlayerPicker")
    if existing then existing:Destroy() return end

    local picker = Instance.new("Frame")
    picker.Name = "PlayerPicker"
    picker.Size = UDim2.new(0, 200, 0, 0)
    picker.Position = UDim2.new(0, 290, 0.5, -100)
    picker.BackgroundColor3 = Color3.fromRGB(15, 15, 28)
    picker.BorderSizePixel = 0
    picker.AutomaticSize = Enum.AutomaticSize.Y
    picker.ZIndex = 5
    picker.Parent = ScreenGui
    Instance.new("UICorner", picker).CornerRadius = UDim.new(0, 10)
    Instance.new("UIListLayout", picker).Padding = UDim.new(0, 4)
    local pp = Instance.new("UIPadding", picker)
    pp.PaddingTop = UDim.new(0, 6)
    pp.PaddingBottom = UDim.new(0, 6)
    pp.PaddingLeft = UDim.new(0, 6)
    pp.PaddingRight = UDim.new(0, 6)

    local header = Instance.new("TextLabel")
    header.Size = UDim2.new(1, 0, 0, 26)
    header.BackgroundTransparency = 1
    header.Text = "Select Player"
    header.TextColor3 = Color3.fromRGB(180, 180, 255)
    header.TextSize = 13
    header.Font = Enum.Font.GothamBold
    header.ZIndex = 5
    header.Parent = picker

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 32)
        btn.BackgroundColor3 = Color3.fromRGB(30, 30, 55)
        btn.Text = p.Name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 12
        btn.Font = Enum.Font.Gotham
        btn.BorderSizePixel = 0
        btn.ZIndex = 5
        btn.Parent = picker
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
        btn.MouseButton1Click:Connect(function()
            picker:Destroy()
            local char = p.Character
            if not char then Notify("Player has no character") return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local myHRP = GetHRP()
            if not myHRP then return end
            if Settings.TeleportTween then
                local goal = hrp.CFrame * CFrame.new(0, 0, 3)
                TweenService:Create(myHRP, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {CFrame = goal}):Play()
            else
                myHRP.CFrame = hrp.CFrame * CFrame.new(0, 0, 3)
            end
            Notify("Teleported to " .. p.Name)
        end)
    end

    task.delay(8, function()
        if picker and picker.Parent then picker:Destroy() end
    end)
end)

MakeButton("Teleport to Spawn", Color3.fromRGB(30, 100, 80), function()
    local spawn = Workspace:FindFirstChildWhichIsA("SpawnLocation", true)
    local hrp = GetHRP()
    if hrp and spawn then
        hrp.CFrame = spawn.CFrame + Vector3.new(0, 5, 0)
        Notify("Teleported to Spawn!")
    else
        Notify("Spawn not found")
    end
end)

MakeButton("Teleport to Nearest Car", Color3.fromRGB(50, 50, 120), function()
    local hrp = GetHRP()
    if not hrp then return end
    local closest, closestDist = nil, math.huge
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name:lower():find("car") then
            local root = obj:FindFirstChild("Body") or obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if root then
                local dist = (root.Position - hrp.Position).Magnitude
                if dist < closestDist then closestDist = dist; closest = root end
            end
        end
    end
    if closest then
        hrp.CFrame = CFrame.new(closest.Position + Vector3.new(0, 4, 0))
        Notify("Teleported to car!")
    else
        Notify("No car found nearby")
    end
end)

