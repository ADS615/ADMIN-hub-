local AllTabs = {}
local function MakeTab(name)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 82, 0, 22) btn.BackgroundColor3 = Color3.fromRGB(26, 26, 52)
    btn.Text = name btn.TextColor3 = Color3.fromRGB(150, 150, 195) btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold btn.BorderSizePixel = 0 btn.ZIndex = 4 btn.Parent = TabRow
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
    local tab = { btn = btn, cards = {} }
    btn.MouseButton1Click:Connect(function()
        for _, t in ipairs(AllTabs) do
            for _, c in ipairs(t.cards) do c.Visible = false end
            t.btn.BackgroundColor3 = Color3.fromRGB(26, 26, 52)
            t.btn.TextColor3 = Color3.fromRGB(150, 150, 195)
        end
        for _, c in ipairs(tab.cards) do c.Visible = true end
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 165) btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        CardScroll.CanvasPosition = Vector2.new(0, 0)
    end)
    table.insert(AllTabs, tab)
    return tab
end

