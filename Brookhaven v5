    frame.BorderSizePixel = 0 frame.AutomaticSize = Enum.AutomaticSize.Y
    frame.ZIndex = 40 frame.Parent = Gui
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
    Instance.new("UIStroke", frame).Color = Color3.fromRGB(65, 65, 185)
    local layout = Instance.new("UIListLayout", frame) layout.Padding = UDim.new(0, 3)
    local pad = Instance.new("UIPadding", frame)
    pad.PaddingTop = UDim.new(0, 5) pad.PaddingBottom = UDim.new(0, 5)
    pad.PaddingLeft = UDim.new(0, 5) pad.PaddingRight = UDim.new(0, 5)
    local hdr = Instance.new("TextLabel", frame)
    hdr.Size = UDim2.new(1, 0, 0, 20) hdr.BackgroundTransparency = 1
    hdr.Text = title hdr.TextColor3 = Color3.fromRGB(150, 150, 245)
    hdr.TextSize = 11 hdr.Font = Enum.Font.GothamBold hdr.ZIndex = 41
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local btn = Instance.new("TextButton", frame)
        btn.Size = UDim2.new(1, 0, 0, 26) btn.BackgroundColor3 = Color3.fromRGB(26, 26, 52)
        btn.Text = p.Name btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 11 btn.Font = Enum.Font.Gotham btn.BorderSizePixel = 0 btn.ZIndex = 41
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
        btn.MouseButton1Click:Connect(function() frame:Destroy() callback(p) end)
    end
    task.delay(7, function() if frame and frame.Parent then frame:Destroy() end end)
end

