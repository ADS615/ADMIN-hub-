local function Notify(text, color)
    local f = Instance.new("TextLabel")
    f.Size = UDim2.new(0, 250, 0, 34) f.Position = UDim2.new(0.5, -125, 0, -40)
    f.BackgroundColor3 = color or Color3.fromRGB(22, 22, 55)
    f.TextColor3 = Color3.fromRGB(255, 255, 255) f.Text = text
    f.TextSize = 12 f.Font = Enum.Font.GothamBold f.BorderSizePixel = 0
    f.ZIndex = 60 f.TextWrapped = true f.Parent = Gui
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 8)
    TweenService:Create(f, TweenInfo.new(0.25), {Position = UDim2.new(0.5, -125, 0, 10)}):Play()
    task.delay(2.5, function()
        TweenService:Create(f, TweenInfo.new(0.25), {Position = UDim2.new(0.5, -125, 0, -40)}):Play()
        task.delay(0.3, function() f:Destroy() end)
    end)
end

