local bypassCard = MakeCard(bypassTab, "Ban Bypass")
AddButton(bypassCard, "Remove All Barriers", Color3.fromRGB(148, 28, 28), function()
    local removed = 0
    for _, obj in ipairs(workspace:GetDescendants()) do
        local name = obj.Name:lower()
        if obj:IsA("BasePart") or obj:IsA("UnionOperation") then
            if name:find("ban") or name:find("barrier") or name:find("block")
            or name:find("wall") or name:find("invisible") then
                if obj.CanCollide and obj.Transparency >= 0.8 then
                    obj.CanCollide = false obj.Transparency = 1
                    removed += 1
                end
            end
            if obj.Transparency == 1 and obj.CanCollide then
                obj.CanCollide = false removed += 1
            end
        end
        if obj:IsA("ForceField") then
            obj:Destroy() removed += 1
        end
    end
    Notify("Removed " .. removed .. " barriers!", Color3.fromRGB(30, 120, 30))
end)
AddButton(bypassCard, "Bypass All Doors", Color3.fromRGB(125, 50, 12), function()
    local count = 0
    for _, obj in ipairs(workspace:GetDescendants()) do
        local name = obj.Name:lower()
        if obj:IsA("BasePart") then
            if name:find("door") or name:find("gate") or name:find("entry") then
                obj.CanCollide = false count += 1
            end
        end
    end
    Notify("Bypassed " .. count .. " doors!")
end)
AddButton(bypassCard, "Clear Invisible Walls", Color3.fromRGB(100, 22, 65), function()
    local count = 0
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency == 1 and obj.CanCollide then
            obj.CanCollide = false count += 1
        end
