local function AddButton(parent, label, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 28) btn.BackgroundColor3 = color or Color3.fromRGB(28, 28, 58)
    btn.Text = label btn.TextColor3 = Color3.fromRGB(255, 255, 255) btn.TextSize = 10
