local function createRow(entry, idx)
    local accent = ROW_ACCENTS[idx] or Color3.fromRGB(200,200,200)

    local row = Instance.new("Frame",scroll)
    row.Name=entry.name row.Size=UDim2.new(1,0,0,56)
    row.BackgroundColor3=Color3.fromRGB(17,17,26) row.BorderSizePixel=0
    row.LayoutOrder=idx
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,9)

    -- left accent bar
    local bar = Instance.new("Frame",row)
    bar.Size=UDim2.new(0,3,0.65,0) bar.Position=UDim2.new(0,8,0.175,0)
    bar.BackgroundColor3=accent bar.BorderSizePixel=0
    Instance.new("UICorner",bar).CornerRadius=UDim.new(0,3)

    -- icon
    local icon = Instance.new("TextLabel",row)
    icon.Text=entry.icon or "•" icon.Font=Enum.Font.GothamBold icon.TextSize=22
    icon.BackgroundTransparency=1 icon.Size=UDim2.new(0,32,1,0)
    icon.Position=UDim2.new(0,18,0,0) icon.TextXAlignment=Enum.TextXAlignment.Center

    -- name label
    local nameLbl = Instance.new("TextLabel",row)
    nameLbl.Text=entry.name nameLbl.Font=Enum.Font.GothamBold nameLbl.TextSize=13
    nameLbl.TextColor3=Color3.fromRGB(220,220,235) nameLbl.BackgroundTransparency=1
    nameLbl.Size=UDim2.new(1,-100,0,20) nameLbl.Position=UDim2.new(0,56,0,9)
    nameLbl.TextXAlignment=Enum.TextXAlignment.Left

    -- status label
    local statusLbl = Instance.new("TextLabel",row)
    statusLbl.Text="Disabled" statusLbl.Font=Enum.Font.Gotham statusLbl.TextSize=11
    statusLbl.TextColor3=Color3.fromRGB(90,90,110) statusLbl.BackgroundTransparency=1
    statusLbl.Size=UDim2.new(1,-100,0,14) statusLbl.Position=UDim2.new(0,56,0,30)
    statusLbl.TextXAlignment=Enum.TextXAlignment.Left

    -- pill background
    local pill = Instance.new("Frame",row)
    pill.Size=UDim2.new(0,50,0,26) pill.Position=UDim2.new(1,-62,0.5,-13)
    pill.BackgroundColor3=Color3.fromRGB(30,30,46) pill.BorderSizePixel=0
    Instance.new("UICorner",pill).CornerRadius=UDim.new(1,0)

    -- pill knob
    local knob = Instance.new("Frame",pill)
    knob.Size=UDim2.new(0,20,0,20) knob.Position=UDim2.new(0,3,0.5,-10)
    knob.BackgroundColor3=Color3.fromRGB(90,90,110) knob.BorderSizePixel=0
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)

    -- invisible click catcher
    local btn = Instance.new("TextButton",row)
    btn.Size=UDim2.new(1,0,1,0) btn.BackgroundTransparency=1 btn.Text="" btn.ZIndex=5

    local isOn = entry.enabled

    local function setVisual(on)
        local ti = TweenInfo.new(0.18,Enum.EasingStyle.Quad)
        if on then
            TweenService:Create(pill, ti,{BackgroundColor3=accent}):Play()
            TweenService:Create(knob, ti,{Position=UDim2.new(0,27,0.5,-10),BackgroundColor3=Color3.fromRGB(255,255,255)}):Play()
            TweenService:Create(row,  ti,{BackgroundColor3=Color3.fromRGB(14,20,28)}):Play()
            statusLbl.Text="Active" statusLbl.TextColor3=accent
        else
            TweenService:Create(pill, ti,{BackgroundColor3=Color3.fromRGB(30,30,46)}):Play()
            TweenService:Create(knob, ti,{Position=UDim2.new(0,3,0.5,-10),BackgroundColor3=Color3.fromRGB(90,90,110)}):Play()
            TweenService:Create(row,  ti,{BackgroundColor3=Color3.fromRGB(17,17,26)}):Play()
            statusLbl.Text="Disabled" statusLbl.TextColor3=Color3.fromRGB(90,90,110)
        end
    end

    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        entry.enabled = isOn
        if entry.module and entry.module.Config then
            entry.module.Config.Enabled = isOn
        end
        -- Release aimbot lock when turning off
        if entry.module == Aimbot and not isOn then
            Aimbot:ReleaseLock()
        end
        setVisual(isOn)
    end)

    setVisual(isOn)
end

