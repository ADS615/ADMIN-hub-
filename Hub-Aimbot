local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")
local Camera      = workspace.CurrentCamera

-- ============================================================
--  SHARED UTILITY
-- ============================================================
local function nd(class, props)
    local d = Drawing.new(class)
    for k,v in pairs(props) do d[k]=v end
    return d
end

local function getNPCs()
    local npcs, pm = {}, {}
    for _,p in ipairs(Players:GetPlayers()) do
        if p.Character then pm[p.Character] = true end
    end
    for _,obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and not pm[obj] and obj:FindFirstChildOfClass("Humanoid") then
            table.insert(npcs, obj)
        end
    end
    return npcs
end

-- ============================================================
--  MODULE 1 – NPC ESP
-- ============================================================
local ESP = (function()
    local M = {}
    M.Config = {
        Enabled        = false,
        MaxDistance    = 200,
        ShowName       = true,
        ShowHealth     = true,
        ShowDistance   = true,
        ShowState      = true,
        ShowBox        = true,
        ShowTracers    = false,
        ShowLOS        = true,
        TextSize       = 14,
        BoxColor       = Color3.fromRGB(255,255,255),
        NameColor      = Color3.fromRGB(255,255,255),
        HealthColor    = Color3.fromRGB(0,255,0),
        LowHealthColor = Color3.fromRGB(255,60,60),
        TracerColor    = Color3.fromRGB(255,255,0),
        LOSColor       = Color3.fromRGB(255,50,50),
        StateColors    = {
            Idle   = Color3.fromRGB(150,150,255),
            Patrol = Color3.fromRGB(100,220,100),
            Alert  = Color3.fromRGB(255,200,50),
            Chase  = Color3.fromRGB(255,140,0),
            Attack = Color3.fromRGB(255,50,50),
            Dead   = Color3.fromRGB(120,120,120),
        },
    }

    local drawings = {}

    local function getOrCreate(npc)
        if drawings[npc] then return drawings[npc] end
        local cfg = M.Config
        local d   = { box = {} }
        for i=1,4 do d.box[i]=nd("Line",{Color=cfg.BoxColor,Thickness=1,Visible=false}) end
        d.name   = nd("Text",{Color=cfg.NameColor,  Size=cfg.TextSize,  Center=true,Outline=true,Visible=false})
        d.health = nd("Text",{Color=cfg.HealthColor,Size=cfg.TextSize-2,Center=true,Outline=true,Visible=false})
        d.dist   = nd("Text",{Color=Color3.fromRGB(200,200,200),Size=cfg.TextSize-2,Center=true,Outline=true,Visible=false})
        d.state  = nd("Text",{Color=Color3.fromRGB(150,150,255),Size=cfg.TextSize-2,Center=true,Outline=true,Visible=false})
        d.tracer = nd("Line",{Color=cfg.TracerColor,Thickness=1,Visible=false})
        drawings[npc] = d
        return d
    end

    local function hideAll()
        for _,d in pairs(drawings) do
            for _,l in ipairs(d.box) do l.Visible=false end
            d.name.Visible=false d.health.Visible=false
            d.dist.Visible=false d.state.Visible=false d.tracer.Visible=false
        end
    end

    local function getCorners(cf,size)
        local h,c = size/2,{}
        for _,sx in ipairs({-1,1}) do for _,sy in ipairs({-1,1}) do for _,sz in ipairs({-1,1}) do
            table.insert(c, cf:PointToWorldSpace(Vector3.new(sx*h.X,sy*h.Y,sz*h.Z)))
        end end end
        return c
    end

    local function getBounds(corners)
        local x1,y1,x2,y2 = math.huge,math.huge,-math.huge,-math.huge
        for _,wp in ipairs(corners) do
            local sp,on = Camera:WorldToViewportPoint(wp)
            if not on then return nil end
            if sp.X<x1 then x1=sp.X end if sp.Y<y1 then y1=sp.Y end
            if sp.X>x2 then x2=sp.X end if sp.Y>y2 then y2=sp.Y end
        end
        return x1,y1,x2,y2
    end

    local function drawRect(lines,x1,y1,x2,y2,col)
        lines[1].From=Vector2.new(x1,y1) lines[1].To=Vector2.new(x2,y1) lines[1].Color=col lines[1].Visible=true
        lines[2].From=Vector2.new(x1,y2) lines[2].To=Vector2.new(x2,y2) lines[2].Color=col lines[2].Visible=true
        lines[3].From=Vector2.new(x1,y1) lines[3].To=Vector2.new(x1,y2) lines[3].Color=col lines[3].Visible=true
        lines[4].From=Vector2.new(x2,y1) lines[4].To=Vector2.new(x2,y2) lines[4].Color=col lines[4].Visible=true
    end

    local function getState(npc)
        local a = npc:GetAttribute("AIState")
        if a then return tostring(a) end
        local sv = npc:FindFirstChild("AIState")
        if sv and sv:IsA("StringValue") then return sv.Value end
        local h = npc:FindFirstChildOfClass("Humanoid")
        if h and h.Health<=0 then return "Dead" end
        return "Idle"
    end

    local function checkLOS(npc)
        local char = LocalPlayer.Character if not char then return false end
        local hrp  = char:FindFirstChild("HumanoidRootPart") if not hrp then return false end
        local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart if not root then return false end
        local dir  = hrp.Position - root.Position
        local hit  = workspace:FindPartOnRayWithIgnoreList(Ray.new(root.Position,dir.Unit*dir.Magnitude),{npc,char})
        return hit==nil
    end

    RunService.RenderStepped:Connect(function()
        if not M.Config.Enabled then hideAll() return end
        local cfg  = M.Config
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local live = {}

        for _,npc in ipairs(getNPCs()) do
            live[npc]=true
            local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart or npc:FindFirstChildOfClass("BasePart")
            if not root then continue end
            local dist   = hrp and (hrp.Position-root.Position).Magnitude or math.huge
            local sp,on  = Camera:WorldToViewportPoint(root.Position)
            local d      = getOrCreate(npc)
            if dist>cfg.MaxDistance or not on then
                for _,l in ipairs(d.box) do l.Visible=false end
                d.name.Visible=false d.health.Visible=false d.dist.Visible=false
                d.state.Visible=false d.tracer.Visible=false
                continue
            end
            local los    = cfg.ShowLOS and checkLOS(npc)
            local boxCol = los and cfg.LOSColor or cfg.BoxColor
            local x1,y1,x2,y2 = getBounds(getCorners(root.CFrame,root.Size))
            if x1 then
                drawRect(d.box,x1,y1,x2,y2,boxCol)
                local cx,yo = (x1+x2)/2, y1-4
                if cfg.ShowName then
                    d.name.Text=npc.Name d.name.Position=Vector2.new(cx,yo) d.name.Visible=true
                    yo=yo-d.name.TextBounds.Y-2
                else d.name.Visible=false end
                local hum = npc:FindFirstChildOfClass("Humanoid")
                if cfg.ShowHealth and hum then
                    local pct=math.clamp(hum.Health/hum.MaxHealth,0,1)
                    d.health.Text=string.format("HP %d/%d",hum.Health,hum.MaxHealth)
                    d.health.Color=pct>0.5 and cfg.HealthColor or cfg.LowHealthColor
                    d.health.Position=Vector2.new(cx,yo) d.health.Visible=true
                    yo=yo-d.health.TextBounds.Y-2
                else d.health.Visible=false end
                if cfg.ShowDistance then
                    d.dist.Text=string.format("%.1f studs",dist)
                    d.dist.Position=Vector2.new(cx,y2+2) d.dist.Visible=true
                else d.dist.Visible=false end
                if cfg.ShowState then
                    local st=getState(npc)
                    d.state.Text="["..st.."]"
                    d.state.Color=cfg.StateColors[st] or Color3.new(1,1,1)
                    d.state.Position=Vector2.new(cx,y2+14) d.state.Visible=true
                else d.state.Visible=false end
            else
                for _,l in ipairs(d.box) do l.Visible=false end
                d.name.Visible=false d.health.Visible=false d.dist.Visible=false d.state.Visible=false
            end
            if cfg.ShowTracers then
                local vp=Camera.ViewportSize
                d.tracer.From=Vector2.new(vp.X/2,vp.Y) d.tracer.To=Vector2.new(sp.X,sp.Y)
                d.tracer.Color=los and cfg.LOSColor or cfg.TracerColor d.tracer.Visible=true
            else d.tracer.Visible=false end
        end

        for npc,d in pairs(drawings) do
            if not live[npc] then
                for _,l in ipairs(d.box) do l:Remove() end
                d.name:Remove() d.health:Remove() d.dist:Remove() d.state:Remove() d.tracer:Remove()
                drawings[npc]=nil
            end
        end
    end)

    return M
end)()

-- ============================================================
--  MODULE 2 – NPC AIMBOT  (FOV circle + smooth head tracking)
-- ============================================================
local Aimbot = (function()
    local M = {}
    M.Config = {
        Enabled        = false,
        FOVRadius      = 120,       -- pixels radius of the FOV circle
        Smoothness     = 0.15,      -- lerp factor per frame (lower = smoother but slower)
        AimPart        = "Head",    -- "Head" or "HumanoidRootPart"
        MaxDistance    = 300,       -- max stud range
        ShowFOV        = true,      -- draw the white/red circle
        ShowLockLine   = true,      -- draw a line from centre to locked head
        FOVIdle        = Color3.fromRGB(255,255,255),   -- circle colour when nobody locked
        FOVLocked      = Color3.fromRGB(255,60,60),     -- circle colour when locked
        LockLineColor  = Color3.fromRGB(255,60,60),
    }

    -- ── FOV circle (64 line segments) ────────────────────────
    local SEG = 64
    local fovLines = {}
    for i = 1, SEG do
        fovLines[i] = nd("Line", { Color=M.Config.FOVIdle, Thickness=1.2, Visible=false })
    end

    -- Lock-on line  (centre → target head)
    local lockLine = nd("Line", { Color=M.Config.LockLineColor, Thickness=1.2, Visible=false })

    -- Small dot at exact screen centre
    local dot = nd("Circle", { Color=Color3.fromRGB(255,60,60), Filled=true, Thickness=0, Radius=3, Visible=false })

    local lockedTarget = nil  -- current NPC being tracked

    -- ── Helpers ──────────────────────────────────────────────
    local function screenCentre()
        local vp = Camera.ViewportSize
        return Vector2.new(vp.X/2, vp.Y/2)
    end

    local function drawCircle(centre, radius, col)
        for i = 1, SEG do
            local a1 = (i-1)/SEG * math.pi*2
            local a2 =  i   /SEG * math.pi*2
            fovLines[i].From    = Vector2.new(centre.X + math.cos(a1)*radius, centre.Y + math.sin(a1)*radius)
            fovLines[i].To      = Vector2.new(centre.X + math.cos(a2)*radius, centre.Y + math.sin(a2)*radius)
            fovLines[i].Color   = col
            fovLines[i].Visible = true
        end
        dot.Position = centre
        dot.Visible  = true
    end

    local function hideCircle()
        for _,l in ipairs(fovLines) do l.Visible=false end
        lockLine.Visible = false
        dot.Visible      = false
    end

    local function getHeadScreen(npc)
        local part = npc:FindFirstChild(M.Config.AimPart)
            or npc:FindFirstChild("HumanoidRootPart")
            or npc.PrimaryPart
        if not part then return nil end
        local sp, on = Camera:WorldToViewportPoint(part.Position)
        if not on then return nil end
        return Vector2.new(sp.X, sp.Y), part
    end

    local function worldDist(npc)
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local root = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
        if not hrp or not root then return math.huge end
        return (hrp.Position - root.Position).Magnitude
    end

    local function isAlive(npc)
        local h = npc:FindFirstChildOfClass("Humanoid")
        return h and h.Health > 0
    end

    -- ── Render loop ───────────────────────────────────────────
    RunService.RenderStepped:Connect(function()
        if not M.Config.Enabled then
            hideCircle()
            lockedTarget = nil
            return
        end

        local cfg    = M.Config
        local centre = screenCentre()
        local radius = cfg.FOVRadius

        -- Drop lock if target died / removed
        if lockedTarget then
            if not lockedTarget.Parent or not isAlive(lockedTarget) then
                lockedTarget = nil
            end
        end

        -- Scan NPCs – find the one closest to screen centre that's inside FOV
        local bestNPC, bestDist = nil, math.huge
        for _, npc in ipairs(getNPCs()) do
            if not isAlive(npc) then continue end
            if worldDist(npc) > cfg.MaxDistance then continue end
            local sp = getHeadScreen(npc)
            if not sp then continue end
            local d2d = (sp - centre).Magnitude
            if d2d <= radius and d2d < bestDist then
                bestDist = d2d
                bestNPC  = npc
            end
        end

        -- Update lock
        if bestNPC then
            lockedTarget = bestNPC
        end

        -- ── Draw FOV circle ───────────────────────────────────
        if cfg.ShowFOV then
            drawCircle(centre, radius, lockedTarget and cfg.FOVLocked or cfg.FOVIdle)
        else
            for _,l in ipairs(fovLines) do l.Visible=false end
            dot.Visible = false
        end

        -- ── Aim at locked target ──────────────────────────────
        if lockedTarget then
            local sp, part = getHeadScreen(lockedTarget)
            if sp and part then
                -- Draw lock line
                if cfg.ShowLockLine then
                    lockLine.From    = centre
                    lockLine.To      = sp
                    lockLine.Color   = cfg.LockLineColor
                    lockLine.Visible = true
                else
                    lockLine.Visible = false
                end

                -- Smooth camera lerp toward the head
                local lookCF = CFrame.new(Camera.CFrame.Position, part.Position)
                Camera.CFrame = Camera.CFrame:Lerp(lookCF, cfg.Smoothness)
            else
                -- Off screen – release lock
                lockedTarget     = nil
                lockLine.Visible = false
            end
        else
            lockLine.Visible = false
        end
    end)

    function M:ReleaseLock() lockedTarget = nil end
    return M
end)()

